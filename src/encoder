#define ENCODER_PIN 9
#define NORMAL_RPM 200
#define ENCODER_PULSES_PER_ROTATION 20

bool last_reading;
bool current_readin;


volatile uint16_t count = 0;
uint16_t total_rpm;

void setup() {
  pinMode(ENCODER_PIN, INPUT_PULLUP);
  
  last_reading = digitalRead(ENCODER_PIN);
  attachInterrupt(digitalPinToInterrupt(ENCODER_PIN), updateMotorPosition, CHANGE);

}

void loop() {
  // put your main code here, to run repeatedly:
  total_rpm = RPM_CAL(count);
  Serial.print("Encoder: ");
  Serial.print(count);
  Serial.print(" , ");
  Serial.print("TOTAL RPM: ");
  Serial.print(total_rpm);
}

void updateMotorPosition(){
  bool current_reading = digitalRead(ENCODER_PIN);

  if(current_reading != last_reading){
    count++;
  }

  last_reading = current_reading;

}

uint16_t RPM_CAL(uint16_t COUNT){
  uint16_t RPM = ((COUNT/ENCODER_PULSES_PER_ROTATION) * 60) / 2;
  return RPM;
}
