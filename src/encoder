#define ENCODER_PIN 2
#define ENCODER_PULSES_PER_ROTATION 20

volatile long count = 0;     // updated inside interrupt
bool last_reading = 0;

unsigned long lastTime = 0;
long lastCount = 0;

void setup() {
  Serial.begin(115200);

  pinMode(ENCODER_PIN, INPUT_PULLUP);   // use INPUT if your encoder already has proper external pull-up/down

  last_reading = digitalRead(ENCODER_PIN);

  attachInterrupt(digitalPinToInterrupt(ENCODER_PIN), countEncoder, CHANGE);

  lastTime = millis();
}

void loop() {
  unsigned long currentTime = millis();

  // calculate RPM every 1000 ms
  if (currentTime - lastTime >= 1000) {
    noInterrupts();
    long currentCount = count;
    interrupts();

    long deltaCount = currentCount - lastCount;
    float rpm = (deltaCount * 60.0) / ENCODER_PULSES_PER_ROTATION;

    Serial.print("Encoder Count: ");
    Serial.print(currentCount);
    Serial.print(" , RPM: ");
    Serial.println(rpm);

    lastCount = currentCount;
    lastTime = currentTime;
  }
}

void countEncoder() {
  bool current_reading = digitalRead(ENCODER_PIN);

  if (current_reading != last_reading) {
    count++;
    last_reading = current_reading;
  }
}

